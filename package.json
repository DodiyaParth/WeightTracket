{
  "name": "weighttracker-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Repo root — dev/build/test default to the production app in application/. The design prototype is a standalone project in design/.",
  "scripts": {
    "dev": "npm --prefix application run dev",
    "build": "npm --prefix application run build",
    "preview": "npm --prefix application run preview",
    "test": "npm --prefix application run test",
    "test:coverage": "npm --prefix application run test:coverage",
    "test:e2e": "npm --prefix application run test:e2e",
    "typecheck": "npm --prefix application run typecheck",
    "seed": "npm --prefix application run seed",
    "setup": "npm install && npm --prefix application install",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
