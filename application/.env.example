# WeightTracker — Firebase web app config.
# Copy this file to ".env.local" and paste the values from your Firebase project:
#   Firebase console → Project settings (gear) → "Your apps" → Web app → SDK setup & config.
#
# These values are NOT secret — the client API key is meant to ship in the browser
# bundle. Real security lives in Firestore Security Rules (see REQUIREMENTS.md §7).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (only if you enabled Google Analytics for the project):
VITE_FIREBASE_MEASUREMENT_ID=
